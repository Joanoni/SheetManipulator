# =============================================================================
# SheetManipulator — .gitignore
# =============================================================================

# -----------------------------------------------------------------------------
# AEGIS Agent Framework (runtime-generated, never commit)
# -----------------------------------------------------------------------------
agent_framework/config.json
agent_framework/first_prompt_chat_cycle.md
agent_framework/first_prompt_chat_setup.md
agent_framework/framework.md
agent_framework/memory/
agent_framework/tmp/
agent_framework/first_prompt_chat_execution.md
agent_framework/first_prompt_chat_planning.md

# -----------------------------------------------------------------------------
# Python / FastAPI
# -----------------------------------------------------------------------------
__pycache__/
**/__pycache__/
*.py[cod]
*$py.class
*.pyo

# Virtual environments
.venv/
venv/
env/
ENV/
.env/
Lib/
Scripts/

# Distribution / packaging
dist/
build/
*.egg-info/
*.egg
.eggs/

# Testing & coverage
.pytest_cache/
.coverage
coverage.xml
htmlcov/
*.log

# Type checkers / linters
.mypy_cache/
.ruff_cache/
.dmypy.json

# -----------------------------------------------------------------------------
# Node.js / React / Vite (Frontend)
# -----------------------------------------------------------------------------
node_modules/
**/node_modules/

# Build output
src/frontend/dist/
src/frontend/build/

# Vite cache
src/frontend/.vite/

# -----------------------------------------------------------------------------
# Environment & Secrets
# -----------------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.production

# -----------------------------------------------------------------------------
# Concurrency — Lock files (runtime-generated by FileLock mechanism)
# NOTE: Keep data templates and config.json intact; only .lock files are ignored
# -----------------------------------------------------------------------------
*.lock
**/*.lock

# -----------------------------------------------------------------------------
# Data files (runtime-generated; source templates should be committed separately)
# -----------------------------------------------------------------------------
data/

# Audit logs (runtime-generated)
logs/

# -----------------------------------------------------------------------------
# OS-specific
# -----------------------------------------------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~

# -----------------------------------------------------------------------------
# IDEs & Editors
# -----------------------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# JetBrains
.idea/
*.iml

# -----------------------------------------------------------------------------
# Miscellaneous
# -----------------------------------------------------------------------------
*.tmp
*.bak
*.orig

logs/